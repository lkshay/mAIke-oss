ANTHROPIC_API_KEY=your_key_here
OPENAI_API_KEY=your_key_here
GEMINI_API_KEY=your_key_here

# Vertex AI (alternative to GEMINI_API_KEY — uses Application Default Credentials)
# Run: gcloud auth application-default login
# GOOGLE_GENAI_USE_VERTEXAI=True
# GOOGLE_CLOUD_PROJECT=your-project-id
# GOOGLE_CLOUD_LOCATION=global

MAIKE_DEFAULT_BUDGET_USD=5.00
MAIKE_WORKSPACE=.
MAIKE_LOG_LEVEL=INFO

# ─── Web search (optional) ───────────────────────────────────────────────
# WebSearch tries backends in priority order: Tavily → Brave → Google CSE.
# If no keys are set, falls back to scraping DuckDuckGo HTML (no key needed,
# but fragile — DDG can change their markup at any time).
#
# Tavily — LLM-optimized search, returns cleaned content (not just snippets).
#   Free tier: 1,000 queries/month.  Sign up: https://tavily.com/
# TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#
# Brave Search — generic search API, high quality, simple setup.
#   Free "Data for AI" tier: 2,000 queries/month.  Sign up:
#   https://api.search.brave.com/app/subscriptions/subscribe
# BRAVE_SEARCH_API_KEY=BSA-xxxxxxxxxxxxxxxxxxxxxxxxxxx
#
# Google Custom Search — highest-quality results but requires a two-piece
# setup: an API key AND a Programmable Search Engine ID (cx).  Free tier:
# 100 queries/day.  See https://programmablesearchengine.google.com/ and
# https://console.cloud.google.com/apis/library/customsearch.googleapis.com
# GOOGLE_SEARCH_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# GOOGLE_SEARCH_ENGINE_ID=a1b2c3d4e5f6g7h8i
